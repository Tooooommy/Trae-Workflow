{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Task Board Schema",
  "description": "AI Team Task Board State Machine Schema",
  "type": "object",
  "required": ["version", "project", "backlog", "inProgress", "blocked", "completed"],
  "properties": {
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "project": {
      "type": "object",
      "required": ["name", "description"],
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "sprints": {
      "type": "array",
      "items": { "$ref": "#/definitions/sprint" }
    },
    "backlog": {
      "type": "array",
      "items": { "$ref": "#/definitions/task" }
    },
    "inProgress": {
      "type": "array",
      "items": { "$ref": "#/definitions/task" }
    },
    "blocked": {
      "type": "array",
      "items": { "$ref": "#/definitions/task" }
    },
    "completed": {
      "type": "array",
      "items": { "$ref": "#/definitions/task" }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "totalTasks": { "type": "integer", "minimum": 0 },
        "completedTasks": { "type": "integer", "minimum": 0 },
        "blockedTasks": { "type": "integer", "minimum": 0 },
        "lastSync": { "type": "string", "format": "date-time" }
      }
    }
  },
  "definitions": {
    "sprint": {
      "type": "object",
      "required": ["id", "name", "startDate", "endDate"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "goal": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "tasks": { "type": "array", "items": { "type": "string" } }
      }
    },
    "task": {
      "type": "object",
      "required": ["id", "title", "status", "assignedTo"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["backlog", "in_progress", "blocked", "completed", "cancelled"]
        },
        "priority": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low"]
        },
        "assignedTo": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "product-strategist",
              "tech-architect",
              "ux-engineer",
              "frontend-specialist",
              "backend-specialist",
              "mobile-specialist",
              "devops-engineer",
              "security-auditor",
              "quality-engineer",
              "performance-specialist",
              "docs-engineer",
              "retro-facilitator"
            ]
          }
        },
        "dependencies": { "type": "array", "items": { "type": "string" } },
        "deliverables": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" },
        "blockedReason": { "type": "string" },
        "notes": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
